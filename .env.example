TAVILY_API_KEY=your_tavily_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Max chars of Tavily web context injected per prompt. Set to 0 to disable the cap.
WEB_CTX_MAX=1200

# Web LLM mode — bypasses Tavily entirely, uses a web-capable model on OpenRouter
# Set WEB_LLM=true to enable. Requires OPENROUTER_API_KEY.
WEB_LLM=false
WEB_LLM_MODEL=google/gemini-2.0-flash-001

# Verification pass (post-generation fact-checking)
VERIFICATION_TAVILY_ENABLED=true
VERIFICATION_CITATIONS_ENABLED=true
VERIFICATION_TAVILY_MAX_CALLS=20
# Max chars of a cited page to pass to the secondary verification model
CITATION_FETCH_MAX_CHARS=3000
